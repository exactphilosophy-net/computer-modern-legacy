            <Ligature components="l" glyph="fl"/>
          </LigatureSet>
        </LigatureSubst>
      </Lookup>
    </LookupList>
  </GSUB>

  <DSIG>
    <!-- note that the Digital Signature will be invalid after recompilation! -->
    <tableHeader flag="0x1" numSigs="0" version="1"/>
  </DSIG>

</ttFont>
